{
  "manifest_version": 3,
  "name": "DSA Problem Tracker",
  "version": "0.1",
  "author": "Sanskar Sovitkar",
  "description": "Extension to track good DSA problems",
  "permissions": [
    "storage",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://maang.in/*"       
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources" : [
    {
      "resources": [
        "assets/bookmarks.png",
        "assets/delete.png",
        "assets/play.png"
      ],
      "matches" : ["<all_urls>"]
    }
  ],
  "action": {
    "default_icon": {
      "16": "assets/exit-icon.png",
      "24": "assets/exit-icon.png",
      "32": "assets/exit-icon.png"
    },
    "default_popup": "popup.html",
    "default_title": "Problem Bar"
  }
}